generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(uuid())
  username    String    @unique
  password    String
  name        String
  role        String
  permissions String[]
  isActive    Boolean   @default(true)
  lastLogin   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employee    Employee?

  @@map("users")
}

model Client {
  id          String    @id
  name        String
  address     String?
  phone       String?
  hasWhatsapp Boolean   @default(false)
  email       String?
  social1     String?
  social2     String?
  social3     String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  invoices    Invoice[]
  sales       Sale[]

  @@map("clients")
}

model Supplier {
  id             String          @id @default(uuid())
  rif            String          @unique
  comercialName  String
  legalName      String?
  contactName    String?
  address        String?
  phone          String?
  email          String?
  category       String?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  purchaseOrders PurchaseOrder[]
  purchases      Purchase[]

  @@map("suppliers")
}

model Purchase {
  id                   String            @id @default(uuid())
  supplierId           String
  invoiceDate          DateTime
  invoiceNumber        String?
  subtotal             Decimal           @db.Decimal(10, 2)
  taxAmount            Decimal           @db.Decimal(10, 2)
  total                Decimal           @db.Decimal(10, 2)
  currencyCode         String            @default("VES")
  exchangeRate         Decimal           @default(1.0) @db.Decimal(10, 4)
  status               String            @default("COMPLETED")
  paymentStatus        String            @default("UNPAID")
  dueDate              DateTime?
  paidAmount           Decimal           @default(0) @db.Decimal(10, 2)
  balance              Decimal           @default(0) @db.Decimal(10, 2)
  userId               String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  purchaseOrderId      String?           @unique
  invoiceControlNumber String?
  items                PurchaseItem[]
  payments             PurchasePayment[]
  purchaseOrder        PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id])
  supplier             Supplier          @relation(fields: [supplierId], references: [id])
  retentions           TaxRetention[]

  @@map("purchases")
}

model PurchaseOrder {
  id           String              @id @default(uuid())
  supplierId   String
  orderDate    DateTime            @default(now())
  expectedDate DateTime?
  subtotal     Decimal             @db.Decimal(10, 2)
  taxAmount    Decimal             @db.Decimal(10, 2)
  total        Decimal             @db.Decimal(10, 2)
  currencyCode String              @default("VES")
  exchangeRate Decimal             @default(1.0) @db.Decimal(10, 4)
  status       String              @default("PENDING")
  notes        String?
  userId       String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  items        PurchaseOrderItem[]
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  purchase     Purchase?

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  productId       String
  quantity        Decimal       @db.Decimal(10, 3)
  cost            Decimal       @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  product         Product       @relation(fields: [productId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@map("purchase_order_items")
}

model PurchasePayment {
  id             String        @id @default(uuid())
  purchaseId     String
  amount         Decimal       @db.Decimal(10, 2)
  paymentDate    DateTime      @default(now())
  paymentMethod  String
  reference      String?
  notes          String?
  createdBy      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  bankAccountId  String?
  bankMovementId String?       @unique
  currencyCode   String        @default("VES")
  exchangeRate   Decimal       @default(1.0) @db.Decimal(10, 4)
  paymentAmount  Decimal?      @db.Decimal(10, 2)
  bankAccount    BankAccount?  @relation(fields: [bankAccountId], references: [id])
  bankMovement   BankMovement? @relation(fields: [bankMovementId], references: [id])
  purchase       Purchase      @relation(fields: [purchaseId], references: [id])

  @@map("purchase_payments")
}

model PurchaseItem {
  id         String   @id @default(uuid())
  purchaseId String
  productId  String
  quantity   Decimal  @db.Decimal(10, 3)
  cost       Decimal  @db.Decimal(10, 2)
  total      Decimal  @db.Decimal(10, 2)
  oldCost    Decimal? @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id])
  purchase   Purchase @relation(fields: [purchaseId], references: [id])

  @@map("purchase_items")
}

model Product {
  id                      String                      @id @default(uuid())
  sku                     String                      @unique
  name                    String
  description             String?
  categoryId              String
  subcategoryId           String?
  currencyId              String
  type                    ProductType                 @default(PRODUCT)
  costPrice               Decimal?                    @db.Decimal(10, 2)
  salePrice               Decimal                     @db.Decimal(10, 2)
  offerPrice              Decimal?                    @db.Decimal(10, 2)
  wholesalePrice          Decimal?                    @db.Decimal(10, 2)
  stock                   Decimal                     @default(0) @db.Decimal(10, 3)
  unitId                  String?
  secondaryUnitId         String?
  unitsPerSecondaryUnit   Int?
  conversionDirection     String?
  secondaryCostPrice      Decimal?                    @db.Decimal(10, 2)
  secondarySalePrice      Decimal?                    @db.Decimal(10, 2)
  secondaryOfferPrice     Decimal?                    @db.Decimal(10, 2)
  secondaryWholesalePrice Decimal?                    @db.Decimal(10, 2)
  isReturnable            Boolean                     @default(true)
  returnDeadlineDays      Int?
  active                  Boolean                     @default(true)
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  images                  String[]                    @default([])
  isTaxExempt             Boolean                     @default(false)
  usedIn                  ProductComponent[]          @relation("ComponentProduct")
  components              ProductComponent[]          @relation("CompositeProduct")
  adjustments             InventoryAdjustment[]
  mlMapping               MercadoLibreProductMapping?
  category                Department                  @relation("ProductCategory", fields: [categoryId], references: [id])
  currency                Currency                    @relation(fields: [currencyId], references: [id])
  secondaryUnit           Unit?                       @relation("ProductSecondaryUnit", fields: [secondaryUnitId], references: [id])
  subcategory             Department?                 @relation("ProductSubcategory", fields: [subcategoryId], references: [id])
  unit                    Unit?                       @relation("ProductPrimaryUnit", fields: [unitId], references: [id])
  purchaseItems           PurchaseItem[]
  purchaseOrderItems      PurchaseOrderItem[]
  returnItems             ReturnItem[]
  replacementReturnItems  ReturnReplacementItem[]
  saleItems               SaleItem[]

  @@map("products")
}

model ProductComponent {
  id                 String   @id @default(uuid())
  compositeProductId String
  componentProductId String
  quantity           Decimal  @db.Decimal(10, 3)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  componentProduct   Product  @relation("ComponentProduct", fields: [componentProductId], references: [id])
  compositeProduct   Product  @relation("CompositeProduct", fields: [compositeProductId], references: [id])

  @@unique([compositeProductId, componentProductId])
}

model CompanySettings {
  id                            String    @id @default(uuid())
  name                          String
  rif                           String
  logoUrl                       String?
  preferredSecondaryCurrencyId  String?
  autoUpdateRates               Boolean   @default(false)
  updateFrequency               Int       @default(60)
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt
  taxEnabled                    Boolean   @default(false)
  taxRate                       Decimal   @default(16.00) @db.Decimal(5, 2)
  roundingEnabled               Boolean   @default(true)
  roundingFactor                Int       @default(10)
  igtfEnabled                   Boolean   @default(false)
  igtfRate                      Decimal   @default(3.00) @db.Decimal(5, 2)
  isSpecialTaxpayer             Boolean   @default(false)
  requireBankAccountForPayments Boolean   @default(true)
  preferredSecondaryCurrency    Currency? @relation(fields: [preferredSecondaryCurrencyId], references: [id])

  @@map("company_settings")
}

model Department {
  id                    String       @id @default(uuid())
  name                  String
  description           String?
  parentId              String?
  active                Boolean      @default(true)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  parent                Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children              Department[] @relation("DepartmentHierarchy")
  productsAsCategory    Product[]    @relation("ProductCategory")
  productsAsSubcategory Product[]    @relation("ProductSubcategory")

  @@map("departments")
}

model Unit {
  id                  String    @id @default(uuid())
  name                String    @unique
  abbreviation        String
  active              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  productsAsSecondary Product[] @relation("ProductSecondaryUnit")
  productsAsPrimary   Product[] @relation("ProductPrimaryUnit")

  @@map("units")
}

model Currency {
  id              String            @id @default(uuid())
  name            String            @unique
  code            String            @unique
  symbol          String
  isPrimary       Boolean           @default(false)
  exchangeRate    Decimal?          @db.Decimal(10, 4)
  isAutomatic     Boolean           @default(false)
  apiSymbol       String?
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  bankAccounts    BankAccount[]
  companySettings CompanySettings[]
  products        Product[]

  @@map("currencies")
}

model Sale {
  id                 String         @id @default(uuid())
  date               DateTime       @default(now())
  invoiceNumber      String         @unique
  clientId           String?
  subtotal           Decimal        @db.Decimal(10, 2)
  discount           Decimal        @default(0) @db.Decimal(10, 2)
  tax                Decimal        @default(0) @db.Decimal(10, 2)
  total              Decimal        @db.Decimal(10, 2)
  paymentMethod      String
  tendered           Decimal?       @db.Decimal(10, 2)
  change             Decimal?       @db.Decimal(10, 2)
  hasReturns         Boolean        @default(false)
  isCancelled        Boolean        @default(false)
  cashSessionId      String?
  active             Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  exchangeRate       Decimal        @default(1.0) @db.Decimal(10, 4)
  igtfAmount         Decimal        @default(0) @db.Decimal(10, 2)
  controlNumber      String?
  cashMovements      CashMovement[]
  invoice            Invoice?
  replacementReturns Return[]       @relation("ReturnNewSale")
  returns            Return[]       @relation("OriginalSale")
  items              SaleItem[]
  cashSession        CashSession?   @relation(fields: [cashSessionId], references: [id])
  client             Client?        @relation(fields: [clientId], references: [id])

  @@map("sales")
}

model SaleItem {
  id          String   @id @default(uuid())
  saleId      String
  productId   String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cost        Decimal  @default(0) @db.Decimal(10, 2)
  isTaxExempt Boolean  @default(false)
  product     Product  @relation(fields: [productId], references: [id])
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("sale_items")
}

model InvoiceCounter {
  id            String   @id @default(uuid())
  prefix        String   @default("FAC")
  currentNumber Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("invoice_counters")
}

model Invoice {
  id            String         @id @default(uuid())
  number        String         @unique
  clientId      String
  saleId        String?        @unique
  subtotal      Decimal        @db.Decimal(10, 2)
  discount      Decimal        @default(0) @db.Decimal(10, 2)
  tax           Decimal        @default(0) @db.Decimal(10, 2)
  total         Decimal        @db.Decimal(10, 2)
  status        String         @default("PENDING")
  dueDate       DateTime?
  paidAmount    Decimal        @default(0) @db.Decimal(10, 2)
  balance       Decimal        @db.Decimal(10, 2)
  notes         String?
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  currencyCode  String         @default("VES")
  exchangeRate  Decimal        @default(1) @db.Decimal(10, 4)
  controlNumber String?
  client        Client         @relation(fields: [clientId], references: [id])
  sale          Sale?          @relation(fields: [saleId], references: [id])
  payments      Payment[]
  retentions    TaxRetention[]

  @@map("invoices")
}

model Payment {
  id            String   @id @default(uuid())
  invoiceId     String
  amount        Decimal  @db.Decimal(10, 2)
  paymentDate   DateTime @default(now())
  paymentMethod String
  reference     String?
  notes         String?
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  invoice       Invoice  @relation(fields: [invoiceId], references: [id])

  @@map("payments")
}

model TaxRetention {
  id               String    @id @default(uuid())
  type             String
  voucherNumber    String    @unique
  voucherDate      DateTime  @default(now())
  amount           Decimal   @db.Decimal(10, 2)
  baseAmount       Decimal   @db.Decimal(10, 2)
  retentionPercent Decimal   @db.Decimal(5, 2)
  invoiceId        String?
  purchaseId       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  invoice          Invoice?  @relation(fields: [invoiceId], references: [id])
  purchase         Purchase? @relation(fields: [purchaseId], references: [id])

  @@map("tax_retentions")
}

model Return {
  id               String                  @id @default(uuid())
  originalSaleId   String
  creditNoteNumber String                  @unique
  returnType       String
  reason           String
  productCondition String
  refundAmount     Decimal?                @db.Decimal(10, 2)
  refundMethod     String?
  newSaleId        String?
  status           String                  @default("PENDING")
  requestedBy      String?
  approvedBy       String?
  approvedAt       DateTime?
  notes            String?
  active           Boolean                 @default(true)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  controlNumber    String?
  items            ReturnItem[]
  replacementItems ReturnReplacementItem[]
  newSale          Sale?                   @relation("ReturnNewSale", fields: [newSaleId], references: [id])
  originalSale     Sale                    @relation("OriginalSale", fields: [originalSaleId], references: [id])

  @@map("returns")
}

model ReturnItem {
  id              String  @id @default(uuid())
  returnId        String
  productId       String
  quantity        Decimal @db.Decimal(10, 3)
  unitPrice       Decimal @db.Decimal(10, 2)
  total           Decimal @db.Decimal(10, 2)
  restockQuantity Int     @default(0)
  product         Product @relation(fields: [productId], references: [id])
  return          Return  @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@map("return_items")
}

model ReturnReplacementItem {
  id        String  @id @default(uuid())
  returnId  String
  productId String
  quantity  Decimal @db.Decimal(10, 3)
  unitPrice Decimal @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)
  product   Product @relation(fields: [productId], references: [id])
  return    Return  @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@map("return_replacement_items")
}

model CashRegister {
  id        String        @id @default(uuid())
  name      String
  location  String?
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  sessions  CashSession[]

  @@map("cash_registers")
}

model CashSession {
  id               String             @id @default(uuid())
  registerId       String
  openedBy         String
  closedBy         String?
  openedAt         DateTime           @default(now())
  closedAt         DateTime?
  status           String             @default("OPEN")
  openingBalance   Decimal            @db.Decimal(10, 2)
  openingNotes     String?
  expectedBalance  Decimal?           @db.Decimal(10, 2)
  actualBalance    Decimal?           @db.Decimal(10, 2)
  variance         Decimal?           @db.Decimal(10, 2)
  closingNotes     String?
  active           Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  cashierId        String?
  verificationDiff Decimal?           @db.Decimal(10, 2)
  verifiedAt       DateTime?
  verifiedBy       String?
  bankMovements    BankMovement[]
  movements        CashMovement[]
  register         CashRegister       @relation(fields: [registerId], references: [id])
  sales            Sale[]
  cashCounts       SessionCashCount[]

  @@map("cash_sessions")
}

model SessionCashCount {
  id           String      @id @default(uuid())
  sessionId    String
  type         String
  currencyCode String
  value        Decimal     @db.Decimal(10, 2)
  quantity     Int
  total        Decimal     @db.Decimal(10, 2)
  createdAt    DateTime    @default(now())
  session      CashSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("session_cash_counts")
}

model CurrencyDenomination {
  id           String   @id @default(uuid())
  currencyCode String
  value        Decimal  @db.Decimal(10, 2)
  label        String
  type         String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("currency_denominations")
}

model CashMovement {
  id           String      @id @default(uuid())
  sessionId    String
  type         String
  amount       Decimal     @db.Decimal(10, 2)
  currencyCode String      @default("VES")
  saleId       String?
  description  String
  notes        String?
  performedBy  String
  createdAt    DateTime    @default(now())
  exchangeRate Decimal     @default(1.0) @db.Decimal(10, 4)
  sale         Sale?       @relation(fields: [saleId], references: [id])
  session      CashSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("cash_movements")
}

model InventoryAdjustment {
  id            String   @id @default(uuid())
  productId     String
  type          String
  quantity      Decimal  @db.Decimal(10, 3)
  previousStock Decimal  @db.Decimal(10, 3)
  newStock      Decimal  @db.Decimal(10, 3)
  reason        String
  notes         String?
  performedBy   String
  createdAt     DateTime @default(now())
  product       Product  @relation(fields: [productId], references: [id])

  @@map("inventory_adjustments")
}

model Expense {
  id                   String        @id @default(uuid())
  description          String
  amount               Decimal       @db.Decimal(10, 2)
  currencyCode         String        @default("VES")
  exchangeRate         Decimal       @default(1) @db.Decimal(10, 4)
  date                 DateTime      @default(now())
  category             String
  paymentMethod        String
  reference            String?
  notes                String?
  userId               String?
  cashMovementId       String?       @unique
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  bankAccountId        String?
  bankMovementId       String?       @unique
  isTaxable            Boolean       @default(false)
  taxAmount            Decimal       @default(0) @db.Decimal(10, 2)
  invoiceControlNumber String?
  invoiceNumber        String?
  bankAccount          BankAccount?  @relation(fields: [bankAccountId], references: [id])
  bankMovement         BankMovement? @relation(fields: [bankMovementId], references: [id])

  @@map("expenses")
}

model Employee {
  id               String           @id @default(uuid())
  firstName        String
  lastName         String
  identification   String           @unique
  email            String?
  phone            String?
  address          String?
  position         String
  department       String?
  baseSalary       Decimal          @db.Decimal(10, 2)
  currency         String           @default("VES")
  hireDate         DateTime         @default(now())
  isActive         Boolean          @default(true)
  paymentFrequency PaymentFrequency @default(BIWEEKLY)
  userId           String?          @unique
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User?            @relation(fields: [userId], references: [id])
  payments         PayrollPayment[]

  @@map("employees")
}

model PayrollPeriod {
  id          String           @id @default(uuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  paymentDate DateTime?
  status      String           @default("DRAFT")
  totalAmount Decimal          @default(0) @db.Decimal(12, 2)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  payments    PayrollPayment[]

  @@map("payroll_periods")
}

model PayrollPayment {
  id              String               @id @default(uuid())
  payrollPeriodId String
  employeeId      String
  baseSalary      Decimal              @db.Decimal(10, 2)
  currency        String
  exchangeRate    Decimal              @default(1) @db.Decimal(10, 4)
  totalIncome     Decimal              @db.Decimal(10, 2)
  totalDeductions Decimal              @db.Decimal(10, 2)
  netAmount       Decimal              @db.Decimal(10, 2)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  items           PayrollPaymentItem[]
  employee        Employee             @relation(fields: [employeeId], references: [id])
  payrollPeriod   PayrollPeriod        @relation(fields: [payrollPeriodId], references: [id])

  @@map("payroll_payments")
}

model PayrollPaymentItem {
  id               String         @id @default(uuid())
  payrollPaymentId String
  type             String
  description      String
  amount           Decimal        @db.Decimal(10, 2)
  payrollPayment   PayrollPayment @relation(fields: [payrollPaymentId], references: [id], onDelete: Cascade)

  @@map("payroll_payment_items")
}

model BankAccount {
  id                     String            @id @default(uuid())
  bankName               String
  accountNumber          String
  accountType            String            @default("CHECKING")
  holderName             String
  holderId               String
  currencyId             String
  balance                Decimal           @default(0) @db.Decimal(12, 2)
  active                 Boolean           @default(true)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  pendingLiquidation     Decimal           @default(0) @db.Decimal(12, 2)
  receivesMobilePayment  Boolean           @default(false)
  receivesPosLiquidation Boolean           @default(false)
  currency               Currency          @relation(fields: [currencyId], references: [id])
  movements              BankMovement[]
  expenses               Expense[]
  purchasePayments       PurchasePayment[]

  @@map("bank_accounts")
}

model BankMovement {
  id              String           @id @default(uuid())
  bankAccountId   String
  type            String
  amount          Decimal          @db.Decimal(12, 2)
  category        String
  description     String
  reference       String?
  date            DateTime         @default(now())
  cashSessionId   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  bankAccount     BankAccount      @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  cashSession     CashSession?     @relation(fields: [cashSessionId], references: [id])
  expense         Expense?
  purchasePayment PurchasePayment?

  @@map("bank_movements")
}

model SaleControlCounter {
  id            String   @id @default(uuid())
  prefix        String   @default("00")
  currentNumber Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("sale_control_counters")
}

model MercadoLibreAccount {
  id              String                       @id @default(uuid())
  mlUserId        String                       @unique
  username        String?
  accessToken     String
  refreshToken    String
  expiresIn       Int
  scope           String?
  tokenType       String?
  updatedAt       DateTime                     @updatedAt
  createdAt       DateTime                     @default(now())
  productMappings MercadoLibreProductMapping[]

  @@map("mercadolibre_accounts")
}

model MercadoLibreProductMapping {
  id          String              @id @default(uuid())
  productId   String              @unique
  mlItemId    String              @unique
  mlPermalink String?
  mlAccountId String
  syncEnabled Boolean             @default(true)
  lastSync    DateTime?
  syncStatus  String?
  syncError   String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  mlAccount   MercadoLibreAccount @relation(fields: [mlAccountId], references: [id])
  product     Product             @relation(fields: [productId], references: [id])

  @@map("mercadolibre_product_mappings")
}

enum ProductType {
  PRODUCT
  SERVICE
  COMPOSED
}

enum PaymentFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}
